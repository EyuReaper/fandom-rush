# Supabase Connection String (from Connect > URI)
DATABASE_URL="postgresql://postgres.[ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# BetterAuth Secret (Generate one with `npx better-auth secret`)
BETTER_AUTH_SECRET=""

# BetterAuth URL (Base URL of your server)
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
